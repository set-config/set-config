{
  "name": "@set-config/cli",
  "version": "0.0.12",
  "description": "Full-featured set-config CLI wrapper",
  "type": "module",
  "bin": {
    "set-config": "./dist/bin/set-config"
  },
  "files": ["dist"],
  "scripts": {
    "build": "node scripts/build.ts",
    "prepublishOnly": "exit 1",
    "publish": "cd dist && npm publish"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vite": "npm:rolldown-vite@latest"
  },
  "dependencies": {
    "@set-config/core": "workspace:*",
    "@set-config/yaml": "workspace:*",
    "@set-config/toml": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/set-config/set-config"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
