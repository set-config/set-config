{
  "name": "@set-config/core",
  "version": "0.3.0",
  "description": "CLI engine for set-config - adapter loader and CLI framework",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./src/lib.ts",
      "default": "./dist/index.js"
    },
    "./lib": {
      "types": "./src/lib.ts",
      "default": "./dist/index.js"
    },
    "./cli": "./dist/cli.js"
  },
  "bin": {
    "set-config": "./dist/bin/set-config"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.ts",
    "prepublishOnly": "exit 1",
    "publish": "cd dist && npm publish"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vite": "npm:rolldown-vite@latest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/set-config/set-config"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
