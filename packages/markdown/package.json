{
  "name": "@set-config/markdown",
  "version": "0.3.0",
  "description": "Markdown adapter for set-config",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "set-config": "./dist/bin/set-config"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.ts",
    "prepublishOnly": "exit 1",
    "publish": "cd dist && npm publish"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vite": "npm:rolldown-vite@latest"
  },
  "dependencies": {
    "@set-config/core": "workspace:*",
    "@set-config/yaml": "workspace:*",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-frontmatter": "^2.0.1",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "micromark": "^4.0.2",
    "micromark-extension-frontmatter": "^2.0.0",
    "micromark-extension-gfm": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/set-config/set-config"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
